---
import BaseLayout from "../layouts/BaseLayout.astro";
import ScheduleItem, {
  type Concert,
  type ScheduleEntry,
} from "../components/ScheduleItem.astro";
import scheduleData from "../data/schedule.json";

// Split into upcoming vs past at build time, then sort
// (upcoming ascending, past most-recent first).
const now = new Date();

// Flatten multi-day entries into one resolved item per day. Per-day fields
// (timestamp/date/time/title) override the shared entry fields, so each day
// sorts into the schedule on its own date like any single event.
const entries = scheduleData as ScheduleEntry[];
const events: Concert[] = entries.flatMap((entry) =>
  entry.days?.length
    ? entry.days.map((day) => ({ ...entry, ...day, days: undefined }))
    : [entry as Concert],
);

const upcoming = events
  .filter((e) => new Date(e.timestamp) > now)
  .sort((a, b) => +new Date(a.timestamp) - +new Date(b.timestamp));

const past = events
  .filter((e) => new Date(e.timestamp) <= now)
  .sort((a, b) => +new Date(b.timestamp) - +new Date(a.timestamp));
---

<BaseLayout title="Schedule" description="Upcoming and past performances.">
  <h2>Schedule</h2>
  {
    upcoming.length === 0 ? (
      <p>No upcoming performances scheduled. Check back soon.</p>
    ) : (
      <ul class="list">
        {upcoming.map((e) => <ScheduleItem event={e} />)}
      </ul>
    )
  }

  <h2>Past Concerts</h2>
  <ul class="list">
    {past.map((e) => <ScheduleItem event={e} />)}
  </ul>
</BaseLayout>
